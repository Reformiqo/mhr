  "html": "<style>\n\t@media screen {\n\t\t.print-format {\n\t\t\twidth: 4in;\n\t\t\tpadding: 0.25in;\n\t\t\theight: auto; /* Automatically adjust to content height */\n\t\t\tmin-height: 1in; /* Optional: set a minimum height if needed */\n\t\t}\n\t}\n</style>\n<link href=\"https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css\" rel=\"stylesheet\">\n<!--<div class=\"print-format\">-->\n    \n<!--</div>-->\n<div class=\"d-flex justify-content-between  \">\n    <div class=\"col-7\">\n        <p><b>Container No:</b> {{doc.custom_container_no}} </p>\n        <p><b>Cone: </b>{{doc.custom_cone}}</p>\n        <p><b>Batch Quantity:</b> {{ doc.batch_qty }} </p>\n        <p><b>Batch Id:</b> {{ doc.name }} </p>\n        <p><b>Item:</b> {{ doc.item }} </p>\n        <p><b>Supplier Batch No:</b> {{ doc.custom_supplier_batch_no }} </p>\n    </div>\n    <div>\n        <img src=\"{{frappe.utils.get_url(doc.custom_qr_image) }}\">\n    </div>\n</div>\n",
