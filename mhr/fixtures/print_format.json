  "format_data": "[{\"fieldname\": \"print_heading_template\", \"fieldtype\": \"Custom HTML\", \"options\": \"<div class=\\\"print-heading text-center border border-1 border-secondary\\\">\\t\\t\\t\\t\\n<h2 class=\\\"text-center\\\"><b>MEHER CREATION</b>\\n</h2>\\n<p>Plot No 30,31 Paikki, 32 Paikki Warehouse No. 2A & 2B,Fairdeal Industrial Park, Surat-Navsari Road, Dabhel, Navsari, Gujrat,3\\n</p>\\n<p><b>TIN GST:</b> 24ABWFM0906C1ZF <b>PAN</b>:ABWFM0906C\\n</p>\\n</div>\\n<div class=\\\"border border-1 border-secondary text-center\\\">\\n    <h4>Packing Slip ( Delivery )</h4>\\n</div>\"}, {\"fieldtype\": \"Section Break\", \"label\": \"\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldname\": \"delivery_note\", \"print_hide\": 0, \"label\": \"Delivery Note\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldtype\": \"Section Break\", \"label\": \"\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldname\": \"from_case_no\", \"print_hide\": 0, \"label\": \"From Package No.\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldname\": \"to_case_no\", \"print_hide\": 0, \"label\": \"To Package No.\"}, {\"fieldtype\": \"Section Break\", \"label\": \"\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldname\": \"items\", \"print_hide\": 0, \"label\": \"Items\", \"visible_columns\": [{\"fieldname\": \"item_code\", \"print_width\": \"100px\", \"print_hide\": 0}, {\"fieldname\": \"item_name\", \"print_width\": \"200px\", \"print_hide\": 0}, {\"fieldname\": \"batch_no\", \"print_width\": \"\", \"print_hide\": 0}, {\"fieldname\": \"description\", \"print_width\": \"\", \"print_hide\": 0}, {\"fieldname\": \"qty\", \"print_width\": \"100px\", \"print_hide\": 0}, {\"fieldname\": \"net_weight\", \"print_width\": \"100px\", \"print_hide\": 0}, {\"fieldname\": \"stock_uom\", \"print_width\": \"100px\", \"print_hide\": 0}, {\"fieldname\": \"weight_uom\", \"print_width\": \"100px\", \"print_hide\": 0}, {\"fieldname\": \"page_break\", \"print_width\": \"\", \"print_hide\": 0}, {\"fieldname\": \"dn_detail\", \"print_width\": \"\", \"print_hide\": 0}, {\"fieldname\": \"pi_detail\", \"print_width\": \"\", \"print_hide\": 0}]}, {\"fieldtype\": \"Section Break\", \"label\": \"Package Weight Details\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldname\": \"net_weight_pkg\", \"print_hide\": 0, \"label\": \"Net Weight\"}, {\"fieldname\": \"net_weight_uom\", \"print_hide\": 0, \"label\": \"Net Weight UOM\"}, {\"fieldtype\": \"Column Break\"}, {\"fieldname\": \"gross_weight_pkg\", \"print_hide\": 0, \"label\": \"Gross Weight\"}, {\"fieldname\": \"gross_weight_uom\", \"print_hide\": 0, \"label\": \"Gross Weight UOM\"}]",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Packing Slip</title>\n    <link href=\"https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css\" rel=\"stylesheet\">\n    <style>\n        .header, .footer {\n            text-align: center;\n        }\n        .details-table, .items-table {\n            width: 100%;\n        }\n        .details-table th, .details-table td, .items-table th, .items-table td {\n            border: 1px solid black;\n        }\n        .items-table th, .items-table td {\n            text-align: center;\n        }\n        .no-border {\n            border: none !important;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"border\">\n        <div class=\"header pt-2\">\n            <h3>MEHER CREATIONS</h3>\n            <p>Plot No 30,31 Falaki, 32 Falaki Warehouse No. 24 A 28, Faridabad Industrial Park, Surat-Navsari Road, Dabhel, Navsari, Gujarat</p>\n            <p>TIN GST: 24ABWFM9506C1ZF PAN: ABWFM9506C</p>\n        </div>\n        <div class=\"header border-top border-bottom\">\n            <h4>Packing Slip (Delivery)</h4>\n        </div>\n       <div class=\"row my-2\">\n           <div class=\"col-6 d-flex\">\n               <p>PS No:</p>\n               <p class=\"ml-4\"><strong>{{ doc.name }}</strong></p>\n           </div>\n           <div class=\"col-6 d-flex justify-content-end\">\n               <p>PS Date:</p>\n               <p class=\"ml-4\">{{ doc.creation[:10] }}</p>\n           </div>\n       </div>\n       <div class=\"row border-top border-bottom py-2\">\n           <div class=\"col-12 d-flex\">\n               <p>CUSTOMER NAME:</p>\n               <p class=\"ml-4\">{{ frappe.db.get_value(\"Delivery Note\", doc.delivery_note, \"customer\") }}</p>\n           </div>\n           <div class=\"col-12 d-flex\">\n               <p>GSTIN:</p>\n               <p class=\"ml-4\"></p>\n           </div>\n       </div>\n       <div class=\"row my-2\">\n           <div class=\"col-6 border-right pb-2 pt-2\">\n               <p>DENIER: <strong>50D/8F | BRIGHT | LOW</strong></p>\n               <p>GRADE: <strong>AA EVEN</strong></p>\n           </div>\n           <div class=\"col-6 pb-2 pt-2\">\n              <p>PULP: <strong>Cotton</strong></p>\n               <p>MERGE NO.: <strong></strong> &nbsp; &nbsp; FSC: <strong>NON-FSC</strong></p>\n           </div>\n       </div>\n\n        <table class=\"items-table mb-4\">\n            <thead>\n                <tr>\n                    <th>Sr. No</th>\n                    <th>Container No.</th>\n                    <th>Lot No</th>\n                    <th>Box No</th>\n                    <!--<th>Merge No.</th>-->\n                    <th>Net KGS</th>\n                    <th>No. Of Cone</th>\n                </tr>\n            </thead>\n            <tbody>\n                {% set del_note = frappe.get_doc(\"Delivery Note\", doc.delivery_note) %}\n                {% set total_net_kgs = 0 %}\n                {% set total_no_of_cone = 0 %}\n                {% for item in del_note.items %}\n                <tr>\n                    <td>{{ loop.index }}</td>\n                    <td>{{ frappe.db.get_value(\"Batch\", item.batch_no, \"custom_container_no\") }}</td>\n                    <td>{{ frappe.db.get_value(\"Batch\", item.batch_no, \"custom_lot_no\") }}</td>\n                    <td>{{ frappe.db.get_value(\"Batch\", item.batch_no, \"custom_supplier_batch_no\") }}</td>\n                    <td>{{ item.qty }}</td>\n                    <td>\n                        {% if item.code %}\n                        {{ item.cone }}\n                        {% set total_no_of_cone = total_no_of_cone + item.cone %}\n                        {% else %}\n                        0\n                        {% endif %}\n                    </td>\n                    {% set total_net_kgs = total_net_kgs + item.qty|int %}\n                </tr>\n                {% endfor %}\n            </tbody>\n            <tfoot>\n                <tr>\n                    <th colspan=\"4\">Sub Total:</th>\n                    <th>{{ total_net_kgs }}</th>\n                    <th>{{ total_no_of_cone }}</th>\n                </tr>\n            </tfoot>\n        </table>\n\n        <div class=\"footer\">\n            <div class=\"row mb-4\">\n                <div class=\"col-6\">\n                    <p>Prepared By: {{ doc.owner }}</p>\n                </div>\n                <div class=\"col-6 text-right\">\n                    <p>For, MEHER CREATIONS</p>\n                </div>\n            </div>\n            <div class=\"row\">\n                <div class=\"col-6\">\n                    <p>Transport No:</p>\n                </div>\n                <div class=\"col-6\">\n                    <p>LR No. & Date: </p>\n                </div>\n            </div>\n        </div>\n    </div>\n</body>\n</html>\n",
