  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Packing Slip</title>\n    <link href=\"https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css\" rel=\"stylesheet\">\n    <style>\n        .header, .footer {\n            text-align: center;\n        }\n        .details-table, .items-table {\n            width: 100%;\n        }\n        .details-table th, .details-table td, .items-table th, .items-table td {\n            border: 1px solid black;\n        }\n        .items-table th, .items-table td {\n            text-align: center;\n        }\n        .no-border {\n            border: none !important;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"border\">\n        <div class=\"header pt-2\">\n            <h3>MEHER CREATIONS</h3>\n            <p>Plot No 30,31 Paikki, 32 Paikki Warehouse No. 24 A 28, Faridabad Industrial Park, Surat-Navsari Road, Dabhel, Navsari, Gujarat</p>\n            <p>TIN GST: 24ABWFM9506C1ZF PAN: ABWFM9506C</p>\n        </div>\n        <div class=\"header border-top border-bottom\">\n            <h4>Packing Slip (Delivery)</h4>\n        </div>\n       <div class=\"row my-2 col-12\">\n           <div class=\"col-6 d-flex\">\n               <p>PS No:</p>\n               <p class=\"ml-4\"><strong>{{ doc.name }}</strong></p>\n           </div>\n           <div class=\"col-6 d-flex justify-content-end\">\n               <p>PS Date:</p>\n               <p class=\"ml-4\">{{ doc.creation }}</p>\n           </div>\n       </div>\n       <div class=\"border py-2 col-12\">\n           <div class=\"col-12 d-flex\">\n               <p>CUSTOMER NAME:</p>\n               <p class=\"ml-4\">{{ frappe.db.get_value(\"Delivery Note\", doc.delivery_note, \"customer\") }}</p>\n           </div>\n           <div class=\"col-12 d-flex\">\n               <p>GSTIN:</p>\n               <p class=\"ml-4\"></p>\n           </div>\n       </div>\n       <div class=\"row col-12  my-2\">\n           <div class=\"col-6 border-right pb-2 pt-2\">\n               <p>DENIER: <strong>{{ doc.items[0].item_code }} | {{ doc.custom_lusture }} | {{ doc.custom_glue }} </strong></p>\n               <p>GRADE: <strong>{{ doc.custom_grade }}</strong></p>\n           </div>\n           <div class=\"col-6 pb-2 pt-2\">\n              <p>PULP: <strong>{{ doc.custom_pulp }}</strong></p>\n               <p>MERGE NO.: <strong>{{ doc.custom_merge_no }}</strong> &nbsp; &nbsp; FSC: <strong>{{ doc.custom_fsc }}</strong></p>\n           </div>\n       </div>\n\n        <table class=\"items-table mb-4\">\n            <thead>\n                <tr>\n                    <th>Sr. No</th>\n                    <th>Container No.</th>\n                    <th>Lot No</th>\n                    <th>Box No</th>\n                    <th>Supplier Batch No.</th>\n                    <th>Net KGS</th>\n                    <th>No. Of Cone</th>\n                </tr>\n                \n            </thead>\n            <tbody>\n                {% set total = namespace(cone = 0) %}\n                {% for item in doc.items %}\n                <tr>\n                    <td>{{ loop.index }}</td>\n                    <td>{{ item.custom_container_no }}</td>\n                    <td>{{ item.custom_lot_no }}</td>\n                    <td>{{ item.batch_no }}</td>\n                    <td>{{ frappe.db.get_value(\"Batch\", item.batch_no, \"custom_supplier_batch_no\" )}}</td>\n\n                    <td>{{ \"%0.3f\" | format(item.qty | float) }}</td>\n                    <td> {{ frappe.db.get_value(\"Batch\", item.batch_no, \"custom_cone\" )}}\n                    </td>\n                    {% set total.cone = total.cone + frappe.db.get_value(\"Batch\", item.batch_no, \"custom_cone\" )|int %}\n                </tr>\n                {% endfor %}\n            </tbody>\n            <tfoot>\n               <tr>\n                    <th colspan=\"5\">Sub Total:</th>\n                    <th>{{ doc.total_qty }}00</th>\n                    <th>{{ total.cone }}</th>\n                </tr>\n\n                <tr>\n                    <th colspan=\"3\">Prepared By: {{ frappe.db.get_value(\"User\", doc.owner, \"full_name\") }}</th>\n                    <th><strong>Total:</strong></th>\n                    <th>{{ doc.items | length }}</th>\n                    <th>{{ doc.total_qty }}</th>\n                    <th>{{ total.cone }}</th>\n                </tr>\n                <tr>\n                    <th colspan=\"4\" class=\"text-left\">\n                        <p>Tempo No: {{ doc.lr_no }} </p>\n                        <p>Transporter Name: {{ doc.driver_name }} </p>\n                        <p>LR No. & Date: {{ doc.lr_date }} </p>\n                    </th>\n                    <th colspan=\"3\">For, MEHER CREATIONS</th>\n                </tr>\n            </tfoot>\n        </table>\n\n    </div>\n</body>\n</html>\n",
