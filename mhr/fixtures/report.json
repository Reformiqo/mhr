  "modified": "2025-05-30 12:11:21.676815",
  "module": "Mhr",
  "name": "Meher Creation Updated",
  "prepared_report": 0,
  "query": "SELECT\n    c.posting_date AS Date,\n    c.container_no AS Container,\n    c.item AS Product,\n    c.pulp AS Pulp,\n    c.lusture AS Lusture,\n    c.glue AS Glue,\n    c.total_cone AS 'Total Cones',\n    c.grade AS Grade,\n    c.merge_no AS 'Mer No',\n    c.lot_no 'Lot No',\n    bi.cone AS Cone,\n    COUNT(CASE WHEN b.batch_qty > 0 THEN 1 END) AS boxes,\n    c.total_cone AS Stock,\n    c.warehouse AS Warehouse,\n    c.cross_section AS 'Cross Section'\nFROM\n    `tabContainer` c\nLEFT JOIN\n    `tabBatch Items` bi ON bi.parent = c.name\nLEFT JOIN\n    `tabBatch` b ON b.name = bi.batch_id\nLEFT JOIN\n    (\n        SELECT\n            custom_container_no\n        FROM\n            `tabBatch`\n        GROUP BY\n            custom_container_no\n    ) sb ON sb.custom_container_no = c.container_no\nWHERE\n    c.docstatus = 1\n    AND c.posting_date BETWEEN %(from_date)s AND %(to_date)s\nGROUP BY\n    c.name, bi.cone\nORDER BY\n    c.posting_date DESC, c.container_no;\n",
  "ref_doctype": "Container",
  "reference_report": null,
  "report_name": "Meher Creation Updated",
  "report_script": null,
