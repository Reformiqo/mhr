  ],
  "is_standard": "No",
  "javascript": "frappe.query_reports[\"DN\"] = {\n    \"filters\": [\n        // MI1-I69 (2026-06-23): the SQL has %(from_date)s + %(to_date)s\n        // BETWEEN clauses — without these filters the initial-load\n        // `filters={}` blew up with KeyError. Default to start-of-month\n        // -> today so the report works on first open; user can widen\n        // the range from the filter bar.\n        {\n            \"fieldname\": \"from_date\",\n            \"label\": __(\"From Date\"),\n            \"fieldtype\": \"Date\",\n            \"default\": frappe.datetime.month_start(),\n            \"reqd\": 1\n        },\n        {\n            \"fieldname\": \"to_date\",\n            \"label\": __(\"To Date\"),\n            \"fieldtype\": \"Date\",\n            \"default\": frappe.datetime.get_today(),\n            \"reqd\": 1\n        },\n        {\n            \"fieldname\": \"transaction_type\",\n            \"label\": __(\"Transaction Type\"),\n            \"fieldtype\": \"Select\",\n            \"options\": \"\\nVFY\\nHTY\",\n            \"default\": \"\",\n            on_change: function () {\n                frappe.query_report.refresh();\n            }\n        }\n    ],\n    onload: function(report) {\n        // MI1-I64 (rework): swap column LABELS based on the\n        // Transaction Type filter (Pulp <-> Type, Glue <-> Product).\n        // Default = VFY view (Pulp / Glue), HTY view = Type / Product.\n        // Fieldnames stay as the SQL aliases (Pulp / Glue) so the data\n        // dicts always resolve.\n        var swap_labels = function() {\n            var hty = report.get_filter_value && report.get_filter_value(\"transaction_type\") === \"HTY\";\n            (report.columns || []).forEach(function(c) {\n                if (c.fieldname === \"Pulp\" || c.id === \"Pulp\") {\n                    c.label = hty ? __(\"Type\") : __(\"Pulp\");\n                }\n                if (c.fieldname === \"Glue\" || c.id === \"Glue\") {\n                    c.label = hty ? __(\"Product\") : __(\"Glue\");\n                }\n            });\n            if (report.datatable && report.data) {\n                report.datatable.refresh(report.data, report.columns);\n            }\n        };\n        // Override refresh so the swap runs every time the user changes\n        // a filter (incl. the new transaction_type one).\n        if (report.refresh && !report._mi1_i64_patched) {\n            report._mi1_i64_patched = true;\n            var orig_refresh = report.refresh.bind(report);\n            report.refresh = function() {\n                var ret = orig_refresh.apply(this, arguments);\n                if (ret && ret.then) {\n                    return ret.then(function(r) { swap_labels(); return r; });\n                }\n                swap_labels();\n                return ret;\n            };\n        }\n    }\n};\n",
  "json": null,
  "letter_head": "Stock Ledger",
  "modified": "2026-06-23 15:01:02.544669",
  "module": "Mhr",
  "name": "DN",
  "prepared_report": 0,
  "query": "SELECT\n    CASE\n      WHEN dn.status = 'Completed' THEN CONCAT('<span style=\"color:green;\">', dn.status, '</span>')\n      WHEN dn.status = 'To Bill' THEN CONCAT('<span style=\"color:orange;\">', dn.status, '</span>')\n      WHEN dn.status = 'To Deliver and Bill' THEN CONCAT('<span style=\"color:blue;\">', dn.status, '</span>')\n      WHEN dn.status = 'Draft' THEN CONCAT('<span style=\"color:gray;\">', dn.status, '</span>')\n      WHEN dn.status = 'Cancelled' THEN CONCAT('<span style=\"color:red;\">', dn.status, '</span>')\n      WHEN dn.status = 'Closed' THEN CONCAT('<span style=\"color:purple;\">', dn.status, '</span>')\n      ELSE dn.status\n    END AS `Status`,\n    CONCAT('<a href=\"/app/delivery-note/', dn.name, '\">', dn.name, '</a>') AS `ID`,\n    dn.challan_number AS `Challan`,\n    dn.posting_date AS `Date`,\n    dni.item_code AS `Denier`,\n    SUBSTRING_INDEX(COALESCE(NULLIF(dn.custom_pulp, ''), b.custom_pulp), '-', -1) AS `Pulp`,\n    SUBSTRING_INDEX(COALESCE(NULLIF(dn.custom_glue, ''), b.custom_glue), '-', -1) AS `Glue`,\n    SUBSTRING_INDEX(COALESCE(NULLIF(dn.custom_lusture, ''), b.custom_lusture), '-', -1) AS `Lusture`,\n    SUBSTRING_INDEX(COALESCE(NULLIF(dn.custom_grade, ''), b.custom_grade), '-', -1) AS `Grade`,\n    SUM(dni.qty) AS `Total Qty`,\n    dn.custom_merge_no AS `Merge No`,\n    dni.custom_lot_no AS `Lot No`,\n    COUNT(dni.name) AS `Item Length`,\n    dni.custom_container_no AS `Container`,\n    dn.customer_name AS `Customer Name`,\n    dn.vehicle_no AS `Vehicle No`,\n    dn.custom_sales_person AS `Sales Person`,\n    SUM(dni.custom_cone) AS `Total Cone`,\n    GROUP_CONCAT(DISTINCT dni.custom_supplier_batch_no SEPARATOR ', ') AS `Supplier Batch No`,\n    dn.driver_name AS `Driver Name`\n  FROM `tabDelivery Note` dn\n  LEFT JOIN `tabDelivery Note Item` dni ON dni.parent = dn.name\n  LEFT JOIN `tabBatch` b ON b.name = dni.batch_no\n  WHERE\n    dn.docstatus < 2\n    AND dn.posting_date BETWEEN %(from_date)s AND %(to_date)s\n  GROUP BY\n    dn.name,\n    dni.item_code,\n    dni.custom_container_no,\n    dni.custom_lot_no\n  ORDER BY dn.posting_date DESC, dn.name, dni.item_code",
  "ref_doctype": "Delivery Note",
