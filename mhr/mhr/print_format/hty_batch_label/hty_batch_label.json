 "font_size": 14,
 "html": "<style>\n@media screen {\n    .print-format {\n        width: 4in;\n        padding: 0.25in;\n        height: auto;\n        min-height: 1in;\n    }\n}\n.hty-label { font-family: Arial, sans-serif; font-size: 11px; }\n.hty-label table { width: 100%; border-collapse: collapse; }\n.hty-label td { padding: 3px 6px; vertical-align: top; }\n.hty-label .k { font-weight: 600; width: 40%; }\n.hty-label .v { width: 60%; }\n.hty-label h4 { margin: 0 0 6px 0; font-size: 13px; }\n</style>\n<div class=\"hty-label\">\n  <h4>HTY \u2014 Batch Label</h4>\n  <table>\n    <tr><td class=\"k\">Container No:</td><td class=\"v\">{{ doc.custom_container_no or \"\" }}</td></tr>\n    <tr><td class=\"k\">Batch ID:</td><td class=\"v\">{{ doc.name }}</td></tr>\n    <tr><td class=\"k\">Lot No:</td><td class=\"v\">{{ doc.custom_lot_no or \"\" }}</td></tr>\n    <tr><td class=\"k\">Item:</td><td class=\"v\">{{ doc.item }}</td></tr>\n    {# HTY relabels \u2014 fieldnames stay as in DB (custom_lusture/glue/pulp),\n       labels in PDF read Colour/Product/Type. #}\n    <tr><td class=\"k\">Colour:</td><td class=\"v\">{{ doc.custom_lusture or \"\" }}</td></tr>\n    <tr><td class=\"k\">Product:</td><td class=\"v\">{{ doc.custom_glue or \"\" }}</td></tr>\n    <tr><td class=\"k\">Type:</td><td class=\"v\">{{ doc.custom_pulp or \"\" }}</td></tr>\n    <tr><td class=\"k\">Grade:</td><td class=\"v\">{{ doc.custom_grade or \"\" }}</td></tr>\n    <tr><td class=\"k\">Cone:</td><td class=\"v\">{{ doc.custom_cone or 0 }}</td></tr>\n    <tr><td class=\"k\">Net Weight:</td><td class=\"v\">{{ doc.batch_qty or 0 }} {{ doc.stock_uom or \"\" }}</td></tr>\n    {# Gross Wt + Sr.No. are NEW HTY fields added on Batch Items child.\n       The Batch master doesn't carry them \u2014 they live per cone row on\n       Container. For per-cone labels they're not directly available;\n       left as placeholders for now. #}\n    <tr><td class=\"k\">Sr. No.:</td><td class=\"v\">{{ doc.get(\"custom_sr_no\", \"\") }}</td></tr>\n    <tr><td class=\"k\">Supplier Batch No:</td><td class=\"v\">{{ doc.custom_supplier_batch_no or \"\" }}</td></tr>\n  </table>\n</div>",
 "idx": 0,
