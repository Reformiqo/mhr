 "css": ":root, ::after, ::before {\n  --print-width: 105.000mm;\n  --print-height: 95.000mm;\n  --print-container-width: 105.000mm;\n  --print-container-height: 95.000mm;\n  --print-margin-top: 0mm;\n  --print-margin-bottom: 0mm;\n  --print-margin-left: 0mm;\n  --print-margin-right: 0mm;\n}\n@page { size: 105mm 95mm; margin: 0mm; }\n",
 "custom_format": 0,
