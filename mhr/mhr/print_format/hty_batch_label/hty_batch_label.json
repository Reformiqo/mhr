 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\n  /* wkhtmltopdf-safe styles. No flex/grid (poor support in WebKit 0.12).\n     Page size + margins are controlled by the Print Format doc settings;\n     we keep CSS focused on layout inside the label. */\n  html, body { margin: 0; padding: 0; }\n  body { font-family: Arial, Helvetica, sans-serif; color: #000; }\n  .hty-label { padding: 4mm 5mm; font-size: 9pt; }\n  table.outer { width: 100%; border-collapse: collapse; }\n  table.outer > tbody > tr > td { vertical-align: top; padding: 0; }\n  table.outer > tbody > tr > td.fields-col { width: 65%; padding-right: 4mm; }\n  table.outer > tbody > tr > td.right-col { width: 35%; text-align: right; }\n\n  table.fields { width: 100%; border-collapse: collapse; }\n  table.fields td { padding: 1mm 2mm; vertical-align: top; line-height: 1.2; }\n  table.fields td.k { font-weight: bold; width: 42%; white-space: nowrap; }\n  table.fields td.v { width: 58%; }\n  table.fields tr.b td { font-weight: bold; }\n\n  .right-col .serial { font-weight: bold; font-size: 10.5pt; margin-bottom: 2mm; }\n  .right-col img.qr { width: 28mm; height: 28mm; }\n  .caption { font-size: 7.5pt; text-align: center; margin-top: 2mm; letter-spacing: 0.3pt; }\n</style>\n{%- set item_code = (doc.item or \"\") -%}\n{# MI1-I62: parse the filament-count digit from the Item code, e.g.\n   \"210/72 7.2 GPD\" -> \"72\". If the code isn't slash-formed, blank. #}\n{%- set cone_val = hty_parse_filament_count(item_code) -%}\n{%- set serial = doc.custom_supplier_batch_no or doc.name -%}\n{%- set qr_payload = (doc.custom_cone|string) + \"_\" + (doc.custom_container_no or \"\") + \"_\" + (doc.custom_lot_no or \"\") -%}\n<div class=\"hty-label\">\n  <table class=\"outer\"><tbody>\n    <tr>\n      <td class=\"fields-col\">\n        <table class=\"fields\"><tbody>\n          <tr class=\"b\"><td class=\"k\">Container No.</td><td class=\"v\">{{ doc.custom_container_no or \"\" }}</td></tr>\n          <tr><td class=\"k\">Pallet No.</td><td class=\"v\">{{ doc.custom_cone or \"\" }}</td></tr>\n          <tr><td class=\"k\">Den/Fil</td><td class=\"v\">{{ item_code }}</td></tr>\n          <tr><td class=\"k\">Cone</td><td class=\"v\">{{ cone_val }}</td></tr>\n          <tr class=\"b\"><td class=\"k\">Net Wt</td><td class=\"v\">{{ \"%.3f\"|format(doc.batch_qty|float) if doc.batch_qty is not none else \"\" }}</td></tr>\n          {# MI1-I62 TODO: Gross Wt has no source field in mhr today. Coerce None\n             to \"\" so the label doesn't render the literal text \"None\". Once a\n             custom_gross_weight field is added (Batch or Batch Items), swap below. #}\n          <tr><td class=\"k\">Gross Wt</td><td class=\"v\">{{ doc.get(\"custom_gross_weight\") or \"\" }}</td></tr>\n          <tr><td class=\"k\">Grade</td><td class=\"v\">{{ doc.custom_grade or \"\" }}</td></tr>\n          <tr><td class=\"k\">Luster</td><td class=\"v\">{{ doc.custom_lusture or \"\" }}</td></tr>\n          <tr><td class=\"k\">Type</td><td class=\"v\">PALLET</td></tr>\n          <tr><td class=\"k\">Lot No.</td><td class=\"v\">{{ doc.custom_lot_no or \"\" }}</td></tr>\n        </tbody></table>\n      </td>\n      <td class=\"right-col\">\n        <div class=\"serial\">{{ serial }}</div>\n        <img class=\"qr\" src=\"{{ hty_qr_data_url(qr_payload) }}\" alt=\"QR\" />\n      </td>\n    </tr>\n  </tbody></table>\n  <div class=\"caption\">{{ qr_payload }}.</div>\n</div>\n",
 "idx": 0,
 "line_breaks": 0,
